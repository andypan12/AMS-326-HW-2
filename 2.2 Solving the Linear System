import random

# Size of the system
N = 126

# Generate matrix A with random values in [-1, 1]
A = [[random.uniform(-1, 1) for j in range(N)] for i in range(N)]

# Generate vector b with all ones
b = [1.0 for i in range(N)]

# -------- Gaussian Elimination with Partial Pivoting --------
for k in range(N):

    # Find pivot row
    max_row = k
    max_val = abs(A[k][k])

    for i in range(k+1, N):
        if abs(A[i][k]) > max_val:
            max_val = abs(A[i][k])
            max_row = i

    # Swap rows in A
    if max_row != k:
        A[k], A[max_row] = A[max_row], A[k]
        b[k], b[max_row] = b[max_row], b[k]

    # Elimination
    for i in range(k+1, N):
        factor = A[i][k] / A[k][k]

        for j in range(k, N):
            A[i][j] -= factor * A[k][j]

        b[i] -= factor * b[k]

# -------- Back Substitution --------
x = [0.0 for i in range(N)]

for i in range(N-1, -1, -1):
    x[i] = b[i]

    for j in range(i+1, N):
        x[i] -= A[i][j] * x[j]

    x[i] /= A[i][i]

# Print solution
print("Solution vector x:")
for i in range(N):
    print(f"x[{i}] =", x[i])
