import random

xmin = -0.7
xmax = 1
ymin = -0.7
ymax = 1

N = 2000000

def inside_region(x, y):
    kidney = (x*x + y*y)**2 <= (x**3 + y**3)
    disc = (x - 0.25)**2 + (y - 0.25)**2 <= 0.125
    return kidney and not disc

count = 0

for i in range(N):

    x = random.uniform(xmin, xmax)
    y = random.uniform(ymin, ymax)

    if inside_region(x,y):
        count += 1

box_area = (xmax-xmin)*(ymax-ymin)

area = box_area * count / N

print("Monte Carlo area =", area)
